rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: can read own profile; admins can read all
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Admin can update any user (for approval/role changes)
    match /users/{userId} {
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // Users can access their own subcollections; admins can read all
    match /users/{userId}/{subcollection}/{docId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Shared research: all authenticated users can read; only admins can write
    match /shared_research/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // CxO Team: meetings collection - users create own, admins read all
    match /meetings/{docId} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow create: if request.auth != null;
    }
    // CxO Team: activity logs - admins read all, authenticated users create
    match /activity_logs/{docId} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow create: if request.auth != null;
    }
    // === Miratuku News App Collections ===
    // Comments on news articles — all authenticated users can read; owners can CUD
    match /news_comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    // Bookmarks — private per user
    match /news_bookmarks/{bookmarkId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    // Foresight queries — private per user
    match /foresight_queries/{queryId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    // User-generated reports — private per user
    match /user_reports/{reportId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    // Insight report admin config
    match /insight_report_config/{docId} {
      allow read, write: if request.auth != null;
    }
    match /insight_report_status/{docId} {
      allow read, write: if request.auth != null;
    }
    match /insight_report_edits/{docId} {
      allow read, write: if request.auth != null;
    }
    // Media sources — admins can manage; all authenticated can read
    match /media_sources/{sourceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Config: public-read items (mythReport) vs admin-only (api keys)
    match /config/mythReport {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /config/{docId} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
